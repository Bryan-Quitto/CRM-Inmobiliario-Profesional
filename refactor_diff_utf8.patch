diff --git a/CRM_Inmobiliario.Api/Features/AgentAi/Services/AgentAiResponseGenerator.cs b/CRM_Inmobiliario.Api/Features/AgentAi/Services/AgentAiResponseGenerator.cs
new file mode 100644
